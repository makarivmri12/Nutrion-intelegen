# ==============================================================================
# TEMPLATE KONFIGURASI ENVIRONMENT VARIABLES (Nutri-Intelligence Platform)
# ==============================================================================
# Salin file ini menjadi `.env` di lingkungan produksi atau lokal Anda.
# Isikan nilai variabel sesuai dengan kebutuhan deployment Anda.

# ------------------------------------------------------------------------------
# 1. VARIABLE WAJIB (REQUIRED)
# ------------------------------------------------------------------------------

# Versi aplikasi saat ini. Digunakan untuk sinkronisasi dan audit log.
# Contoh: "1.0.0"
VITE_APP_VERSION="1.0.0"


# ------------------------------------------------------------------------------
# 2. VARIABLE OPTIONAL (OPSIONAL - UNTUK FITUR CLOUD SYNC & MONITORING)
# ------------------------------------------------------------------------------

# URL endpoint proyek Supabase Anda. Diperlukan untuk sinkronisasi data awan.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Kunci Anonim Supabase untuk autentikasi tingkat klien yang aman.
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here"

# DSN Sentry untuk pemantauan error otomatis di sisi produksi (Error Tracking).
VITE_SENTRY_DSN="https://your-sentry-dsn-key@o0.ingest.sentry.io/000000"

# Kunci API PostHog untuk analitik interaksi pengguna secara real-time.
VITE_POSTHOG_KEY="phc_your_posthog_project_api_key_here"


# ------------------------------------------------------------------------------
# 3. KONFIGURASI SERVER-SIDE SECRET KEYS (DILARANG DIEKSPOS KE CLIENT)
# ------------------------------------------------------------------------------

# Kunci API Google Gemini untuk fungsionalitas AI Asisten Klinis (Server-side Only).
# Jangan gunakan awalan VITE_ agar tidak bocor ke sisi browser/client.
GEMINI_API_KEY="your-gemini-api-key-here"

# URL Backend Server API (jika berjalan di mode full-stack)
APP_URL="http://localhost:3000"
